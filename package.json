{
  "name": "loadout",
  "displayName": "Loadout",
  "description": "Swap your Claude Code setup like equipment. Manage agents, skills, and profiles with a polished panel.",
  "version": "2.0.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "capabilities": {
    "untrustedWorkspaces": { "supported": true }
  },
  "keywords": ["claude", "claude-code", "agents", "skills", "loadout", "profiles"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loadout-bar",
          "title": "Loadout",
          "icon": "./icon-activity.svg"
        }
      ]
    },
    "views": {
      "loadout-bar": [
        {
          "type": "webview",
          "id": "loadout.sidebarView",
          "name": "Loadout"
        }
      ]
    },
    "commands": [
      {
        "command": "loadout.openPanel",
        "title": "Loadout: Open Panel",
        "icon": "$(layers)"
      },
      {
        "command": "loadout.refresh",
        "title": "Loadout: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "loadout.adoptFile",
        "title": "Loadout: Adopt into Workspace"
      },
      {
        "command": "loadout.applyProfile",
        "title": "Loadout: Apply Profile…"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "loadout.openPanel" },
        { "command": "loadout.refresh" }
      ],
      "explorer/context": [
        {
          "command": "loadout.adoptFile",
          "when": "resourceExtname == .md",
          "group": "7_modification@100"
        }
      ]
    },
    "keybindings": [
      {
        "command": "loadout.openPanel",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      }
    ],
    "walkthroughs": [
      {
        "id": "loadout.gettingStarted",
        "title": "Get started with Loadout",
        "description": "Swap your Claude Code setup like equipment.",
        "steps": [
          {
            "id": "openPanel",
            "title": "Open the Loadout panel",
            "description": "Click the Loadout icon in the Activity Bar (or press Cmd+Shift+Alt+C).\n[Open panel](command:loadout.openPanel)",
            "media": { "markdown": "media/walkthrough-open.md" },
            "completionEvents": ["onView:loadout.sidebarView"]
          },
          {
            "id": "exploreWorkspace",
            "title": "Toggle agents and skills",
            "description": "Use the Workspace tab to toggle agents and skills active or inactive. Active items are loaded into every Claude Code session.\n[Open panel](command:loadout.openPanel)",
            "media": { "markdown": "media/walkthrough-workspace.md" },
            "completionEvents": ["onCommand:loadout.openPanel"]
          },
          {
            "id": "applyProfile",
            "title": "Apply a profile",
            "description": "Save your current setup as a named loadout profile and switch between them in one click.\n[Apply a profile](command:loadout.applyProfile)",
            "media": { "markdown": "media/walkthrough-profiles.md" },
            "completionEvents": ["onCommand:loadout.applyProfile"]
          },
          {
            "id": "configure",
            "title": "Configure catalog path (optional)",
            "description": "If your Claude Code catalog lives somewhere other than ~/.claude, set the path in Settings.\n[Open settings](command:workbench.action.openSettings?%5B%22loadout%22%5D)",
            "media": { "markdown": "media/walkthrough-settings.md" },
            "completionEvents": ["onSettingsEdited"]
          }
        ]
      }
    ],
    "configuration": {
      "title": "Loadout",
      "properties": {
        "loadout.globalCatalogPath": {
          "type": "string",
          "default": "",
          "description": "Path to the global agents/skills catalog. Leave empty to use ~/.claude."
        }
      }
    }
  }
}
